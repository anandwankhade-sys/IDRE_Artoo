# ============================================================
# Artoo — Environment Configuration
# Copy this file to .env and fill in every value
# NEVER commit .env to version control
# ============================================================

# ── LLM Provider ────────────────────────────────────────────
# Options: bedrock | openai | gemini
LLM_PROVIDER=gemini

# ── Google Gemini (if LLM_PROVIDER=gemini) ──────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL_ID=gemini-2.5-pro-preview-03-25
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.1

# ── AWS Bedrock (if LLM_PROVIDER=bedrock) ───────────────────
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
# BEDROCK_MAX_TOKENS=8192
# BEDROCK_TEMPERATURE=0.1

# ── OpenAI (if LLM_PROVIDER=openai) ────────────────────────
# OPENAI_API_KEY=YOUR_OPENAI_KEY
# OPENAI_MODEL_ID=gpt-4o
# OPENAI_MAX_TOKENS=8192
# OPENAI_TEMPERATURE=0.1

# ── Jira ─────────────────────────────────────────────────────
JIRA_URL=https://YOUR_INSTANCE.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=YOUR_JIRA_API_TOKEN
JIRA_PROJECTS_FILTER=YOUR_PROJECT_KEY
JIRA_POLL_JQL=project = YOUR_PROJECT AND status = "Ready for Dev" ORDER BY created DESC
JIRA_POLL_INTERVAL_SECONDS=300
JIRA_READ_ONLY=true

# ── Confluence ───────────────────────────────────────────────
CONFLUENCE_URL=https://YOUR_INSTANCE.atlassian.net/wiki
CONFLUENCE_SPACE_KEYS=YOUR_SPACE_KEY
CONFLUENCE_MAX_PAGES=10

# ── GitHub (Source Repo — read access) ───────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=YOUR_GITHUB_PAT
GITHUB_REPO_OWNER=YOUR_ORG
GITHUB_REPO_NAME=YOUR_REPO
GITHUB_BASE_BRANCH=main
GITHUB_DEFAULT_REVIEWERS=

# ── GitHub (PR Target Repo — write access) ───────────────────
# Set these if PRs should go to a different repo than the source
# Leave empty to use the same repo as above
GITHUB_PR_TOKEN=YOUR_PR_GITHUB_TOKEN
GITHUB_PR_REPO_OWNER=YOUR_ORG
GITHUB_PR_REPO_NAME=YOUR_PR_REPO

# ── Database ─────────────────────────────────────────────────
SQLITE_DB_PATH=data/artoo.db
DB_ECHO=false

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
ACTIVITY_LOG_PATH=logs/activity.jsonl
LLM_LOG_PATH=logs/llm_calls.jsonl

# ── Metrics API ──────────────────────────────────────────────
METRICS_PORT=8080
METRICS_API_KEY=change-this-to-a-secret
PR_RECONCILE_INTERVAL_SECONDS=3600

# ── Agent Behaviour ──────────────────────────────────────────
REPO_SCOUT_MAX_FILES=20
COMPLETENESS_THRESHOLD=0.25
LLM_PARSE_RETRY_COUNT=3

# ── Safety ───────────────────────────────────────────────────
# DRY_RUN=true   → no JIRA writes, no GitHub PRs (safe testing)
# DRY_RUN=false  → live mode, creates real PRs
DRY_RUN=true
